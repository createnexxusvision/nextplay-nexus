# NextPlay Nexus — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it contains real secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
DEMO_NOTIFICATION_EMAIL=your_notification_email

# dotenvx encryption (optional — public key only, safe to share)
# DOTENV_PUBLIC_KEY_LOCAL=your_public_key
