# ============================================================
# NextPlay Nexus — .gitignore
# SECURITY: Never commit secrets, keys, or credentials.
# ============================================================

# --- Dependencies ---
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Testing ---
/coverage

# --- Next.js build artifacts ---
/.next/
/out/
/build

# --- Environment & Secrets (NEVER commit these) ---
.env
.env.*
!.env.example
!.env.vault
.env.keys

# --- API Keys & Credentials (belt-and-suspenders) ---
*.key
*.pem
*secret*
*-secret.*
*_secret.*
*token*.txt
*api-key*.txt
*apikey*.txt
Rube-Composio*
gog-client-secret*
credentials.json
*credentials*.json
service-account*.json

# --- OS & Editor ---
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Vercel ---
.vercel

# --- Blockchain / Foundry artifacts ---
/cache/
/broadcast/

# --- Local system config ---
.openclaw_config.yaml
.obsidian-sync.log
.dbclient/
supabase-schema*.sql
